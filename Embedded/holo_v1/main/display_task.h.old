#ifndef DISPLAY_TASK_H
#define DISPLAY_TASK_H

#include "esp_err.h"

#ifdef __cplusplus
extern "C" {
#endif

// Create and start the display task on core 0.
//
// The task waits for encoder notifications, swaps in newly staged frame data at
// the Z index pulse, and advances through the active slice set using PCNT watch
// points computed from ENC_COUNTS_PER_REV.
esp_err_t display_task_start(void);

#ifdef __cplusplus
}
#endif

#endif // DISPLAY_TASK_H
